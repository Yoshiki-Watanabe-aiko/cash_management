# PostgreSQL接続情報（ローカルインストール済みのPostgreSQLを利用）
DATABASE_URL=postgresql+psycopg://cash_mgmt_user:changeme@localhost:5432/cash_management

# Discord Webhook（日次バッチの成功/失敗サマリー通知）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxxxx/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail IMAP + アプリパスワード（個人用・事業用で別アドレス）
GMAIL_PERSONAL_ADDRESS=your-personal@gmail.com
GMAIL_PERSONAL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_BUSINESS_ADDRESS=your-business@gmail.com
GMAIL_BUSINESS_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 振替自動検知用の口座名義文字列（カンマ区切り、全角/半角スペース許容）
ACCOUNT_HOLDER_NAMES=ヤマダタロウ,山田太郎

# 長期休暇期間（年末年始12/31-1/3は固定でコード側に組込済み。それ以外の長期休暇をMM-DD形式で追加設定）
LONG_HOLIDAY_START=
LONG_HOLIDAY_END=

# マネーフォワードME CSVエクスポート取込先フォルダ
IMPORT_TRANSACTIONS_DIR=../import/transactions
IMPORT_ASSETS_DIR=../import/assets

# CORS許可オリジン（フロントエンド開発サーバー）
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
